{
  "name": "my-app",
  "version": "1.0.0",
  "private": true,
  "description": "An Ember app to illustrate core concepts in Ember (v5)",
  "keywords": [
    "ember",
    "emberjs",
    "ember-polaris",
    "ember-tutorial",
    "embroider"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijlee2/ember-workshop.git"
  },
  "license": "MIT",
  "author": "Isaac J. Lee",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input --cache",
    "lint:css:fix": "stylelint \"**/*.css\" --allow-empty-input --fix",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "prelint:types": "type-css-modules --src app",
    "lint:types": "glint",
    "start": "ember serve",
    "test": "ember test --test-port=0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@ember/optional-features": "^2.1.0",
    "@ember/string": "^3.1.1",
    "@ember/test-helpers": "^3.3.0",
    "@ember/test-waiters": "^3.1.0",
    "@embroider/broccoli-side-watch": "0.0.2-unstable.ba9fd29",
    "@embroider/compat": "^3.4.6",
    "@embroider/core": "^3.4.6",
    "@embroider/macros": "^1.15.0",
    "@embroider/router": "^2.1.6",
    "@embroider/webpack": "^3.2.2",
    "@faker-js/faker": "^8.4.1",
    "@glimmer/component": "^1.1.2",
    "@glimmer/tracking": "^1.1.2",
    "@glint/core": "^1.3.0",
    "@glint/environment-ember-loose": "^1.3.0",
    "@glint/environment-ember-template-imports": "^1.3.0",
    "@glint/template": "^1.3.0",
    "@shared-configs/ember-template-lint": "workspace:*",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/stylelint": "workspace:*",
    "@shared-configs/testem": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "@types/qunit": "^2.19.10",
    "@types/sinon": "^17.0.3",
    "autoprefixer": "^10.4.18",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^8.2.2",
    "ember-a11y-refocus": "^3.0.2",
    "ember-a11y-testing": "^6.1.1",
    "ember-auto-import": "^2.7.2",
    "ember-cli": "~5.7.0",
    "ember-cli-app-version": "^6.0.1",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-dependency-checker": "^3.3.2",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-mirage": "^3.0.3",
    "ember-cli-netlify": "^0.4.1",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-composable-helpers": "^5.0.0",
    "ember-concurrency": "^4.0.0",
    "ember-container-query": "^5.0.7",
    "ember-intl": "^6.5.2",
    "ember-load-initializers": "^2.1.2",
    "ember-modifier": "^4.1.0",
    "ember-page-title": "^8.2.2",
    "ember-qunit": "^8.0.2",
    "ember-resolver": "^11.0.1",
    "ember-sinon-qunit": "^7.4.0",
    "ember-source": "~5.7.0",
    "ember-template-imports": "^3.4.2",
    "ember-template-lint": "^5.13.0",
    "ember-test-selectors": "^6.0.0",
    "ember-truth-helpers": "^4.0.3",
    "embroider-css-modules": "^2.0.4",
    "eslint": "^8.57.0",
    "loader.js": "^4.7.0",
    "miragejs": "^0.1.48",
    "my-addon": "workspace:*",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.2.5",
    "qunit": "^2.20.1",
    "qunit-dom": "^3.0.0",
    "sinon": "^17.0.1",
    "stylelint": "^16.2.1",
    "tracked-built-ins": "^3.3.0",
    "type-css-modules": "^1.0.6",
    "typescript": "^5.4.2",
    "webpack": "^5.90.3"
  },
  "engines": {
    "node": "18.* || >= 20"
  },
  "ember": {
    "edition": "octane"
  }
}
