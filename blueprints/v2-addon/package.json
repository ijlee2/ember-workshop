{
  "name": "blueprints-v2-addon",
  "version": "2.1.2",
  "private": true,
  "description": "Blueprints for v2 addons",
  "keywords": [
    "codemod",
    "ember-codemod",
    "emberjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijlee2/ember-workshop.git"
  },
  "license": "MIT",
  "author": "Isaac J. Lee",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": "dist/bin/blueprints-v2-addon.js",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "sh build.sh --production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "test": "sh build.sh --test && mt dist-for-testing --quiet",
    "update-blueprints": "./update-blueprints.mjs"
  },
  "dependencies": {
    "@codemod-utils/ast-javascript": "^4.0.1",
    "@codemod-utils/blueprints": "^3.1.0",
    "@codemod-utils/ember": "^4.1.1",
    "@codemod-utils/files": "^4.0.1",
    "@codemod-utils/package-json": "^4.0.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@codemod-utils/tests": "^3.0.2",
    "@ijlee2-frontend-configs/eslint-config-node": "^3.4.3",
    "@ijlee2-frontend-configs/prettier": "^3.1.1",
    "@sondr3/minitest": "^0.1.2",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^22.19.20",
    "@types/yargs": "^17.0.35",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "git-diff-apply": "^7.0.5",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "22.* || >= 24"
  }
}
