{
  "extends": ["@tsconfig/node22/tsconfig", "@tsconfig/strictest/tsconfig"],
  "compilerOptions": {
    "declaration": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "target": "esnext",
    "types": ["@types/node", "@types/yargs"],
    "verbatimModuleSyntax": true
  },
  "include": ["bin", "src"],
  "exclude": ["src/blueprints"]
}
